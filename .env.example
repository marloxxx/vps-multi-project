# Stack root – setup.sh enforces /opt/stack
OPT_BASE=/opt
STACK_ROOT=/opt/stack

BASE_DOMAIN=example.com
ACME_EMAIL=admin@example.com

# Written by setup.sh after SSH port change (optional reference)
# SSH_PORT=

# Traefik dashboard (required)
# Replaced by setup.sh if unset or contains "change_me".
TRAEFIK_DASHBOARD_AUTH=admin:change_me
TRAEFIK_DASHBOARD_HOST=traefik.example.com

# ---------- Platform services ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong

REDIS_PASSWORD=change_me_redis

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio

# ---------- Paths ----------
POSTGRES_DATA_DIR=/opt/volumes/postgres
REDIS_DATA_DIR=/opt/volumes/redis
MINIO_DATA_DIR=/opt/volumes/minio
BACKUP_DIR=/opt/backups/postgres

# SWAP_SIZE_GB=2
# SWAP_FILE=/swapfile

# ---------- App hosts (replace example.com via setup or sed) ----------
MINIO_CONSOLE_HOST=storage.example.com
MINIO_API_HOST=s3.example.com

# ---------- Portainer (required) ----------
PORTAINER_HOST=portainer.example.com
PORTAINER_DATA_DIR=/opt/volumes/portainer
# PORTAINER_TRAEFIK_AUTH=user:htpasswd_hash

# ---------- Monitoring (started by setup.sh when START_MONITORING=1) ----------
GRAFANA_HOST=grafana.example.com
GRAFANA_ADMIN_PASSWORD=change_me
PROMETHEUS_DATA_DIR=/opt/volumes/prometheus
GRAFANA_DATA_DIR=/opt/volumes/grafana
# GRAFANA_TRAEFIK_AUTH=user:htpasswd_hash

# START_MONITORING=1

# Optional MySQL
# MYSQL_ROOT_PASSWORD=change_me_mysql
# MYSQL_DATA_DIR=/opt/volumes/mysql
